# Backend API base URL. Leave empty in dev to use the Vite proxy (avoids CORS).
# In prod, set to https://api.fci.cloud or wherever the backend lives.
VITE_API_BASE_URL=

# OIDC issuer (bootstrapp identity provider).
VITE_OIDC_ISSUER=https://idp.fci.cloud

# OIDC client_id is the snake_case app name.
VITE_OIDC_CLIENT_ID=oops_no_milk

# Where the IdP redirects back after login. Must be registered with the issuer.
VITE_OIDC_REDIRECT_URI=http://localhost:5173/

# Scopes to request. The IdP rejects 'email' — claims arrive on the access token.
VITE_OIDC_SCOPE=openid profile rest
